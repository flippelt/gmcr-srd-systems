{
  "name": "@lippelt/srd-daggerheart",
  "version": "1.0.0",
  "description": "Daggerheart system module for @lippelt/srd-core — DPCGL, Darrington Press",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippelt/gmcr-srd-systems.git",
    "directory": "packages/daggerheart"
  },
  "peerDependencies": {
    "@lippelt/srd-core": "^1.0.0"
  },
  "devDependencies": {
    "@lippelt/srd-core": "*"
  }
}
