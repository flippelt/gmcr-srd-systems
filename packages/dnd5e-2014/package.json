{
  "name": "@gmcr/srd-dnd5e-2014",
  "version": "0.1.0",
  "description": "D&D 5e (2014) system module for @gmcr/srd-core — SRD 5.1, CC-BY 4.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippelt/gmcr-srd-systems.git",
    "directory": "packages/dnd5e-2014"
  },
  "peerDependencies": {
    "@gmcr/srd-core": "^0.1.0"
  },
  "devDependencies": {
    "@gmcr/srd-core": "*"
  }
}
