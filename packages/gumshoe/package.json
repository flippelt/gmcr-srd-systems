{
  "name": "@gmcr/srd-gumshoe",
  "version": "0.1.0",
  "description": "GUMSHOE system module for @gmcr/srd-core — investigative & general ability mechanics, CC-BY 3.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippelt/gmcr-srd-systems.git",
    "directory": "packages/gumshoe"
  },
  "peerDependencies": {
    "@gmcr/srd-core": "^0.1.0"
  },
  "devDependencies": {
    "@gmcr/srd-core": "*"
  }
}
