{
  "name": "gmcr-srd-systems",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for tabletop RPG system modules (consumed by GM Control Room). Each system is its own publishable package — install only what you need.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "npm run test --workspaces --if-present"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippelt/gmcr-srd-systems.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.8"
  }
}
